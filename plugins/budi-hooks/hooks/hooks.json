{
  "description": "budi hook automation for cost and usage analytics tracking.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "budi hook session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:7878/hook/prompt-submit",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Read|Glob",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:7878/hook/tool-use",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "budi hook subagent-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "budi hook session-end"
          }
        ]
      }
    ]
  }
}
