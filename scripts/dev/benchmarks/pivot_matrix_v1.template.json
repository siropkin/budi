{
  "name": "pivot-matrix-v1",
  "repos": [
    {
      "id": "react",
      "repo_root": "/absolute/path/to/react"
    },
    {
      "id": "flask",
      "repo_root": "/absolute/path/to/flask"
    },
    {
      "id": "express",
      "repo_root": "/absolute/path/to/express"
    },
    {
      "id": "terraform",
      "repo_root": "/absolute/path/to/terraform"
    }
  ],
  "success_gates": {
    "bad_fast_api_rate_all_max": 20.0,
    "bad_fast_api_rate_when_faster_max": 30.0,
    "grounding_delta_min": 0.0
  },
  "variants": [
    {
      "id": "v1_current",
      "enabled": true,
      "notes": "Current behavior baseline",
      "overrides": {}
    },
    {
      "id": "v2_evidence_only",
      "enabled": true,
      "notes": "Smaller context budget + tighter confidence target",
      "overrides": {
        "evidence_only_injection": true,
        "retrieval_limit": 8,
        "context_char_budget": 1800,
        "topk_lexical": 12,
        "topk_vector": 10,
        "min_confidence_to_inject": 0.62
      }
    },
    {
      "id": "v3_slm_critic",
      "enabled": false,
      "requires_slm_critic": true,
      "notes": "Reserved for local SLM control-plane critic (inject/skip arbitration)",
      "overrides": {
        "evidence_only_injection": true,
        "retrieval_limit": 8,
        "context_char_budget": 1800,
        "topk_lexical": 12,
        "topk_vector": 10,
        "min_confidence_to_inject": 0.62
      }
    },
    {
      "id": "v4_strict_abstain",
      "enabled": true,
      "notes": "Highest precision, strongest abstain policy",
      "overrides": {
        "evidence_only_injection": true,
        "retrieval_limit": 6,
        "context_char_budget": 1200,
        "topk_lexical": 10,
        "topk_vector": 8,
        "min_confidence_to_inject": 0.72
      }
    }
  ]
}

